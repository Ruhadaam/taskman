{
  "expo": {
    "name": "Vzbel",
    "slug": "task-management-app",
    "scheme": "vzbel",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/V_white.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/V_white.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/V_black.png",
        "backgroundColor": "#000000"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/V_white.png",
          "color": "#1A1A1A",
          "mode": "production"
        }
      ],
      "expo-font",
      "expo-asset",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/V_white.png",
          "imageWidth": 200,
          "android": {
            "iconBackgroundColor": "#ffffff"
          },
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/V_black.png",
            "android": {
              "iconBackgroundColor": "#000000"
            }
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vzbel.vzbelapp",
      "appleTeamId": "XD9YB38K7P",
      "buildNumber": "1.0.69",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/V_white.png",
        "monochromeImage": "./assets/V_white.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.vzbelapp",
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/V_white.png"
    },
    "extra": {
      "eas": {
        "projectId": "16215e95-d720-4998-aa19-db3edd4efcf9"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/16215e95-d720-4998-aa19-db3edd4efcf9"
    }
  }
}
